---
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  gradientIndex: number;
  featured?: boolean;
}

const { project, gradientIndex, featured = false } = Astro.props;

const gradients = [
  "from-amber-600 to-yellow-500",
  "from-orange-600 to-amber-500",
  "from-yellow-600 to-orange-500",
  "from-amber-700 to-orange-600",
  "from-yellow-500 to-amber-600",
  "from-orange-500 to-yellow-400",
];

const gradient = gradients[gradientIndex % gradients.length];
---

<a
  href={`/projects/${project.slug}`}
  class:list={[
    "group block rounded-lg overflow-hidden",
    "border border-[var(--border)] hover:border-accent",
    "hover:shadow-[0_2px_12px_rgba(180,140,20,0.12)]",
    featured ? "sm:col-span-2" : "",
  ]}
>
  {
    project.data.image ? (
      <div class="relative">
        <img
          src={project.data.image}
          alt={project.data.title}
          class="w-full aspect-video object-cover"
        />
        <div class="p-5 bg-[var(--bg-card)]">
          <h3 class="font-semibold text-lg text-primary group-hover:text-accent transition-colors">
            {project.data.title}
          </h3>
          <p class="text-sm text-secondary mt-2 line-clamp-2">
            {project.data.description}
          </p>
        </div>
      </div>
    ) : (
      <div
        class={`p-5 bg-gradient-to-br ${gradient} min-h-[140px] flex flex-col transition-all duration-300 hover:brightness-110`}
      >
        <h3 class="font-semibold text-lg text-white group-hover:opacity-90 transition-opacity">
          {project.data.title}
        </h3>
        <p class="text-sm text-white/80 mt-1 line-clamp-3">
          {project.data.description}
        </p>
      </div>
    )
  }
</a>
